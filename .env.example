# Slack Integration
# Get this from your Slack App's OAuth & Permissions page
# This should be a User OAuth Token (starts with xoxp-)
SLACK_USER_OAUTH_TOKEN=xoxp-your-token-here

# Upstash Redis (KV Storage)
# Get these from your Upstash dashboard or Vercel Storage integration
KV_REST_API_URL=https://your-redis-url.upstash.io
KV_REST_API_TOKEN=your-upstash-token-here

# Note: If using Vercel AI Gateway, no additional API keys are needed
# The gateway handles AI provider authentication automatically
